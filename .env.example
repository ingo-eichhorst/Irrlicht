# Copy to .env (gitignored) and fill in real values. Used by
# tools/sonarqube-report.sh / the ir:sonarqube-report skill.

# Personal access token from SonarQube Cloud's account security settings.
SONAR_TOKEN=

# This repo's SonarQube Cloud organization key.
SONAR_ORGANIZATION=

# This repo's SonarQube Cloud project key.
SONAR_PROJECT_KEY=
