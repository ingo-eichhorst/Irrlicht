# Keep the linux-replay build context hermetic and small. The Dockerfile only
# needs source + replaydata fixtures; exclude host build output, deps, and VCS
# so the image is identical across dev machines and CI's clean checkout.
.git
.build
**/node_modules
**/.build
platforms/macos/.build
*.dmg
*.pkg
*.tar.gz
.claude/worktrees

# Never let local secrets ride along on a recursive COPY (SonarQube
# docker:S6470) — .env holds SONAR_TOKEN and friends and is gitignored, so it
# exists on disk for plenty of contributors even though it's untracked.
.env
.env.*
!.env.example
