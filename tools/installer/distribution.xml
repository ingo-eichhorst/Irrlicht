<?xml version="1.0" encoding="utf-8"?>
<!--
  distribution.xml — Irrlicht macOS Installer Distribution Definition
  Used by productbuild to create the final Irrlicht-vX.X.X.pkg.

  Template variables (substituted by create-installer-package.sh):
    {{VERSION}}   — e.g. "1.0.0"
    {{BUNDLE_ID}} — e.g. "com.anthropic.irrlicht"
-->
<installer-gui-script minSpecVersion="2">

    <!-- Product metadata -->
    <title>Irrlicht {{VERSION}}</title>
    <organization>com.anthropic</organization>
    <domains enable_localSystem="true" enable_currentUserHome="false"/>
    <options customize="never" require-scripts="true" rootVolumeOnly="true"/>

    <!-- Minimum macOS version -->
    <volume-check>
        <allowed-os-versions>
            <os-version min="13.0"/>
        </allowed-os-versions>
    </volume-check>

    <!-- Welcome, readme, and license screens -->
    <welcome file="welcome.html" mime-type="text/html" uti="public.html"/>
    <license file="LICENSE" mime-type="text/plain"/>

    <!-- Component package references -->
    <pkg-ref id="{{BUNDLE_ID}}" version="{{VERSION}}" auth="root">irrlicht-component.pkg</pkg-ref>

    <!-- Installation choices -->
    <choices-outline>
        <line choice="default">
            <line choice="{{BUNDLE_ID}}"/>
        </line>
    </choices-outline>

    <choice id="default"/>
    <choice id="{{BUNDLE_ID}}" visible="false" title="Irrlicht" description="
Installs the Irrlicht menu bar application, irrlicht-hook receiver, and
configures Claude Code hooks automatically.

Installed components:
  • /Applications/Irrlicht.app
  • /usr/local/bin/irrlicht-hook
  • /usr/local/bin/irrlicht-settings-merger
">
        <pkg-ref id="{{BUNDLE_ID}}"/>
    </choice>

</installer-gui-script>
