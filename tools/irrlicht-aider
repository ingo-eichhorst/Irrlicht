#!/usr/bin/env bash
# irrlicht-aider — wrapper that instruments aider for Irrlicht session monitoring.
#
# Usage:
#   irrlicht-aider [aider-args...]
#
# Install as a shell alias so all aider invocations are instrumented:
#   alias aider='irrlicht-aider'
#
# The wrapper:
#   1. Generates a unique session ID (aider-<timestamp>-<pid>)
#   2. Writes the analytics log to $TMPDIR/irrlicht/aider/<session-id>.jsonl
#   3. Sends a synthetic SessionStart event to irrlicht-hook
#   4. Starts irrlicht-aider-tail in the background to tail the analytics log
#   5. Configures AIDER_NOTIFICATIONS_COMMAND to irrlicht-aider-notify if available
#   6. Runs aider with AIDER_ANALYTICS_LOG pointing at the session log file
#   7. Sends a synthetic SessionEnd event to irrlicht-hook on exit
#
# Kill switch: set IRRLICHT_DISABLED=1 to fall through to plain aider.

set -euo pipefail

# --- kill switch --------------------------------------------------------------

if [ "${IRRLICHT_DISABLED:-0}" = "1" ]; then
    exec aider "$@"
fi

# --- prerequisites -----------------------------------------------------------

if ! command -v irrlicht-hook >/dev/null 2>&1; then
    # Silently fall through if irrlicht-hook is not installed.
    exec aider "$@"
fi

# --- session setup ------------------------------------------------------------

SESSION_ID="aider-$(date +%s)-$$"
LOG_DIR="${TMPDIR:-/tmp}/irrlicht/aider"
LOG_FILE="${LOG_DIR}/${SESSION_ID}.jsonl"
CWD="$(pwd)"

mkdir -p "$LOG_DIR"

# --- send SessionStart --------------------------------------------------------

TIMESTAMP="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
printf '{"hook_event_name":"SessionStart","session_id":"%s","timestamp":"%s","cwd":"%s","model":"","adapter":"aider"}\n' \
    "$SESSION_ID" "$TIMESTAMP" "$CWD" | irrlicht-hook || true

# --- start analytics log tailer -----------------------------------------------

TAILER_PID=""
if command -v irrlicht-aider-tail >/dev/null 2>&1; then
    irrlicht-aider-tail --session "$SESSION_ID" --log "$LOG_FILE" --cwd "$CWD" &
    TAILER_PID="$!"
fi

# --- configure notifications command ------------------------------------------

NOTIFY_ARGS=""
if command -v irrlicht-aider-notify >/dev/null 2>&1; then
    NOTIFY_ARGS="AIDER_NOTIFICATIONS=true AIDER_NOTIFICATIONS_COMMAND=\"irrlicht-aider-notify '${SESSION_ID}'\""
fi

# --- run aider ----------------------------------------------------------------

EXIT_CODE=0
if [ -n "$NOTIFY_ARGS" ]; then
    AIDER_ANALYTICS_LOG="$LOG_FILE" \
    AIDER_ANALYTICS=false \
    AIDER_NOTIFICATIONS=true \
    AIDER_NOTIFICATIONS_COMMAND="irrlicht-aider-notify '${SESSION_ID}'" \
    aider "$@" || EXIT_CODE=$?
else
    AIDER_ANALYTICS_LOG="$LOG_FILE" \
    AIDER_ANALYTICS=false \
    aider "$@" || EXIT_CODE=$?
fi

# --- send SessionEnd ----------------------------------------------------------

TIMESTAMP="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
printf '{"hook_event_name":"SessionEnd","session_id":"%s","timestamp":"%s","cwd":"%s","adapter":"aider"}\n' \
    "$SESSION_ID" "$TIMESTAMP" "$CWD" | irrlicht-hook || true

# --- stop background tailer ---------------------------------------------------

if [ -n "$TAILER_PID" ]; then
    kill "$TAILER_PID" 2>/dev/null || true
fi

exit "$EXIT_CODE"
