#!/bin/bash
# preinstall — Irrlicht installer pre-installation script
#
# Runs before files are copied. Quits any running Irrlicht instance and
# validates the macOS version requirement.

set -euo pipefail

# ---------------------------------------------------------------------------
# macOS version check (requires 13.0 Ventura or later)
# ---------------------------------------------------------------------------
OS_VERSION=$(sw_vers -productVersion)
OS_MAJOR=$(echo "$OS_VERSION" | cut -d. -f1)
OS_MINOR=$(echo "$OS_VERSION" | cut -d. -f2)

if [[ "$OS_MAJOR" -lt 13 ]]; then
    echo "❌  Irrlicht requires macOS 13.0 (Ventura) or later." >&2
    echo "    Detected: macOS $OS_VERSION" >&2
    exit 1
fi

echo "✅  macOS $OS_VERSION — version requirement satisfied"

# ---------------------------------------------------------------------------
# Quit running Irrlicht instance (if any)
# ---------------------------------------------------------------------------
if pgrep -x "Irrlicht" &>/dev/null; then
    echo "Stopping running Irrlicht instance..."
    pkill -x "Irrlicht" || true
    # Give it a moment to exit cleanly
    sleep 1
    echo "   ✅  Irrlicht stopped"
fi

# ---------------------------------------------------------------------------
# Remove stale /usr/local/bin/irrlicht-hook if it exists from a manual install
# ---------------------------------------------------------------------------
if [[ -f /usr/local/bin/irrlicht-hook ]]; then
    echo "Removing existing irrlicht-hook binary..."
    rm -f /usr/local/bin/irrlicht-hook
fi

if [[ -f /usr/local/bin/irrlicht-settings-merger ]]; then
    echo "Removing existing irrlicht-settings-merger binary..."
    rm -f /usr/local/bin/irrlicht-settings-merger
fi

echo "✅  Pre-installation checks complete"
exit 0
